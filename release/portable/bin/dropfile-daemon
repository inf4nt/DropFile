#!/usr/bin/env sh
set -e

REAL_SCRIPT_PATH=$(realpath "$0" 2>/dev/null || readlink -f "$0")
SCRIPT_DIR=$(dirname -- "$REAL_SCRIPT_PATH")
APPLICATION_HOME=$(dirname -- "$SCRIPT_DIR")

JAR_PATH="$APPLICATION_HOME/jars/dropfile-daemon.jar"
LOG_PATH="$APPLICATION_HOME/logs"
SPRING_APPLICATION_PROPERTIES_PATH="$APPLICATION_HOME/conf/dropfile-daemon.application.properties"

DROPFILE_DAEMON_APPLICATION_HOME_DIRECTORY="${DROPFILE_DAEMON_APPLICATION_HOME_DIRECTORY:-$APPLICATION_HOME}"

java \
    -Dlogging.path="$LOG_PATH" \
    -XX:ActiveProcessorCount=1 \
    -Xmx256m -Xms64m \
    -jar "$JAR_PATH" \
    "--spring.config.location=file:$SPRING_APPLICATION_PROPERTIES_PATH" \
    "--dropfile.daemon.application-home.directory=$DROPFILE_DAEMON_APPLICATION_HOME_DIRECTORY" \
    "$@"
